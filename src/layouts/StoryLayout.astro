---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  story: CollectionEntry<'stories'>;
}

const { story } = Astro.props;
const { Content } = await story.render();
const { title, description, pubDate, author, readingTime, tags, category, image } = story.data;

const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric', month: 'short', day: 'numeric'
});

const categories = await getCollection('categories');
const categoryInfo = categories.find((c: CollectionEntry<'categories'>) => c.slug === category);
const kicker = categoryInfo ? categoryInfo.data.title : category;
const meta = [
  readingTime ? `${readingTime} min read` : null,
  formattedDate,
  `By ${author}`,
].filter(Boolean).join(' · ');
---

<BaseLayout
  title={`${title} – The Book of Life`}
  description={description}
  currentPath={`/chapters/stories/${story.slug}`}
  image={image}
  type="article"
  pubDate={pubDate}
  category={kicker}
  readingTime={readingTime}
  tags={tags || []}
>
  <div class="art-scene">
    <div class="art-nav">
      <a href="/chapters" class="art-back">← Back to Chapters</a>
    </div>

    <div class="art-page">
      <div class="art-page-head">
        <span>{kicker}</span>
        <span>The Book of Life</span>
      </div>

      <div class="art-kicker">{kicker}</div>
      <h1 class="art-title">{title}</h1>
      <div class="art-rule"></div>
      <div class="art-meta">{meta}</div>

      {description && (
        <blockquote class="art-pull">{description}</blockquote>
      )}

      <div class="art-body">
        <Content />
      </div>

      <div class="art-page-foot">
        <span>The Book of Life</span>
        <span>Orvi · {new Date(pubDate).getFullYear()}</span>
      </div>
    </div>

    {tags && tags.length > 0 && (
      <div class="art-tags">
        {tags.map((tag: string) => (
          <span class="art-tag">{tag}</span>
        ))}
      </div>
    )}
  </div>
</BaseLayout>

<style>
  .art-scene {
    background: #e6e0d6;
    min-height: calc(100vh - 54px);
    padding: 32px 20px 64px;
  }

  .art-nav {
    max-width: 680px;
    margin: 0 auto 18px;
  }

  .art-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: rgba(90,70,50,0.6);
    font-family: var(--font-sans);
    text-decoration: none;
    transition: color 0.14s;
  }

  .art-back:hover { color: var(--ink); }

  .art-page {
    max-width: 680px;
    margin: 0 auto;
    background: var(--paper);
    border: 0.5px solid rgba(0,0,0,0.1);
    padding: 38px 56px 80px;
    position: relative;
    box-shadow:
      0 4px 28px rgba(0,0,0,0.11),
      0 1px 5px rgba(0,0,0,0.07),
      4px 0 18px rgba(0,0,0,0.04),
      -4px 0 18px rgba(0,0,0,0.04);
    min-height: 640px;
  }

  .art-page-head {
    display: flex;
    justify-content: space-between;
    font-size: 8px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(90,70,50,0.42);
    margin-bottom: 38px;
    padding-bottom: 7px;
    border-bottom: 0.5px solid rgba(0,0,0,0.09);
    font-family: var(--font-sans);
  }

  .art-kicker {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sienna);
    margin-bottom: 12px;
    font-family: var(--font-sans);
  }

  .art-title {
    font-family: var(--font-serif);
    font-size: 40px;
    line-height: 1.06;
    letter-spacing: -0.018em;
    font-weight: 400;
    color: #1a0e06;
    margin-bottom: 14px;
  }

  .art-rule {
    width: 32px;
    height: 1.5px;
    background: var(--sienna);
    margin-bottom: 12px;
  }

  .art-meta {
    font-size: 12px;
    color: rgba(90,70,50,0.60);
    margin-bottom: 30px;
    font-family: var(--font-sans);
  }

  .art-pull {
    border-inline-start: 2px solid var(--sienna);
    padding: 4px 0 4px 18px;
    margin: 0 0 28px;
    font-family: var(--font-serif);
    font-size: 19px;
    line-height: 1.52;
    font-style: italic;
    color: #1a0e06;
  }

  .art-body {
    font-family: var(--font-serif);
    font-size: 17px;
    line-height: 1.88;
    color: #2a1a0a;
  }

  .art-page-foot {
    position: absolute;
    bottom: 22px;
    left: 56px;
    right: 56px;
    display: flex;
    justify-content: space-between;
    font-size: 9px;
    color: rgba(90,70,50,0.38);
    font-family: var(--font-serif);
    border-top: 0.5px solid rgba(0,0,0,0.09);
    padding-top: 7px;
  }

  .art-tags {
    max-width: 680px;
    margin: 18px auto 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .art-tag {
    font-size: 11px;
    color: rgba(90,70,50,0.55);
    font-family: var(--font-sans);
    letter-spacing: 0.04em;
    padding: 3px 10px;
    border: 0.5px solid rgba(90,70,50,0.22);
    border-radius: 2px;
  }

  @media (max-width: 680px) {
    .art-page {
      padding: 28px 24px 72px;
    }
    .art-page-head { display: none; }
    .art-title { font-size: 30px; }
    .art-body { font-size: 16px; }
    .art-page-foot { left: 24px; right: 24px; }
    .art-pull { font-size: 16px; }
  }
</style>

<style is:global>
  .art-body p {
    margin-bottom: 1.45em;
  }

  .art-body p:first-of-type::first-letter {
    float: left;
    font-size: 64px;
    line-height: 0.80;
    padding: 5px 10px 0 0;
    color: var(--sienna);
    font-weight: 400;
    font-family: var(--font-serif);
  }

  .art-body h2 {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    color: #1a0e06;
    margin: 2em 0 0.6em;
  }

  .art-body h3 {
    font-family: var(--font-serif);
    font-size: 18px;
    font-weight: 400;
    color: #1a0e06;
    margin: 1.5em 0 0.5em;
  }

  .art-body blockquote {
    border-inline-start: 2px solid var(--sienna);
    padding: 4px 0 4px 18px;
    margin: 1.5em 0;
    font-style: italic;
    color: rgba(26,14,6,0.75);
  }

  .art-body a {
    color: var(--sienna);
    text-decoration: underline;
    text-decoration-color: rgba(139,94,60,0.35);
    text-underline-offset: 2px;
  }

  .art-body ul, .art-body ol {
    padding-left: 1.5em;
    margin-bottom: 1.45em;
  }

  .art-body li { margin-bottom: 0.4em; }

  .art-body code {
    font-size: 0.88em;
    background: rgba(0,0,0,0.05);
    padding: 0.1em 0.35em;
    border-radius: 2px;
  }

  .art-body pre {
    background: rgba(0,0,0,0.04);
    padding: 1em 1.25em;
    border-radius: 3px;
    overflow-x: auto;
    margin-bottom: 1.45em;
    font-size: 0.88em;
  }

  .art-body pre code {
    background: none;
    padding: 0;
  }

  .art-body img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.5em 0;
  }

  .art-body hr {
    border: none;
    border-top: 0.5px solid rgba(0,0,0,0.14);
    margin: 2em 0;
  }
</style>
