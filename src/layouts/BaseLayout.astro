---
import { ViewTransitions } from 'astro:transitions';
import '../styles/global.css';
import '../styles/transitions.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
import GoogleTagManager from '../components/GoogleTagManager.astro';
import Skeleton from '../components/Skeleton.astro';

interface Props {
  title: string;
  description: string;
  currentPath: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  pubDate?: Date;
  noindex?: boolean;
  /** Article category label, e.g. "Technology" */
  category?: string;
  /** Reading time in minutes */
  readingTime?: number;
  /** Article tags */
  tags?: string[];
}

const {
  title,
  description,
  currentPath,
  image = "/images/default-og.jpg",
  imageAlt,
  type = "website",
  pubDate,
  noindex = false,
  category,
  readingTime,
  tags = [],
} = Astro.props;

const ogImageAlt = imageAlt || title;

const SITE   = 'https://www.robatdasorvi.com';
const AUTHOR = 'Robat Das Orvi';
const AUTHOR_ID = `${SITE}/#orvi`;

const canonicalURL  = new URL(currentPath, SITE).toString();
const socialImage   = new URL(image, SITE).toString();
const datePublished = pubDate ? new Date(pubDate).toISOString() : undefined;
const dateModified  = new Date().toISOString();

const GTM_ID = import.meta.env.PUBLIC_GTM_ID || '';
const GSC_VERIFICATION = import.meta.env.PUBLIC_GSC_VERIFICATION || '';
const GA4_ID = import.meta.env.PUBLIC_GA4_ID || 'G-8MDK069LNK';

// ── Person / author entity (used across all pages) ──────────────────────────
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": AUTHOR_ID,
  "name": AUTHOR,
  "alternateName": "Orvi",
  "url": SITE,
  "description": "Writer, systems thinker, and builder of calm products. Co-creator of OneThread and AgencyHandy.",
  "knowsAbout": [
    "Travel", "Technology", "Artificial Intelligence", "Automation",
    "Startups", "Founder Psychology", "Philosophy", "Psychology", "Football"
  ],
  "sameAs": [
    "https://agencyhandy.com",
    "https://onethread.app"
  ]
};

// ── Website / blog entity ────────────────────────────────────────────────────
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": `${SITE}/#website`,
  "name": "The Book of Life",
  "url": SITE,
  "description": "A collection of long-form essays on travel, technology, startups, philosophy, psychology, and football.",
  "inLanguage": "en-US",
  "author": { "@id": AUTHOR_ID },
  "publisher": { "@id": AUTHOR_ID },
  "potentialAction": {
    "@type": "SearchAction",
    "target": { "@type": "EntryPoint", "urlTemplate": `${SITE}/search?q={search_term_string}` },
    "query-input": "required name=search_term_string"
  }
};

// ── Article schema (only on article pages) ───────────────────────────────────
const articleSchema = type === 'article' ? {
  "@context": "https://schema.org",
  "@type": "Article",
  "@id": canonicalURL,
  "headline": title,
  "name": title,
  "description": description,
  "url": canonicalURL,
  "image": socialImage,
  "datePublished": datePublished,
  "dateModified": dateModified,
  "inLanguage": "en-US",
  "isAccessibleForFree": true,
  "author": { "@id": AUTHOR_ID },
  "publisher": {
    "@type": "Person",
    "@id": AUTHOR_ID,
    "name": AUTHOR
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": canonicalURL },
  ...(category ? { "articleSection": category } : {}),
  ...(readingTime ? { "timeRequired": `PT${readingTime}M` } : {}),
  ...(tags.length ? { "keywords": tags.join(', ') } : {}),
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": [".art-kicker", ".art-title", ".art-pull", ".art-body p:first-of-type"]
  }
} : null;

// ── BreadcrumbList (article pages only) ──────────────────────────────────────
const pathParts = currentPath.replace(/^\/|\/$/g, '').split('/');
const breadcrumbs = type === 'article' && pathParts.length > 1 ? {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": SITE },
    { "@type": "ListItem", "position": 2, "name": "Chapters", "item": `${SITE}/chapters` },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonicalURL }
  ]
} : null;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    {GTM_ID && <GoogleTagManager id={GTM_ID} />}

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Search Console verification (set PUBLIC_GSC_VERIFICATION in .env) -->
    {GSC_VERIFICATION && <meta name="google-site-verification" content={GSC_VERIFICATION} />}

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"} />
    <meta name="author" content={AUTHOR} />
    <meta name="language" content="en" />
    <meta name="theme-color" content="#f5f1eb" />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn, Telegram) -->
    <meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:site_name" content="The Book of Life" />
    <meta property="og:locale" content="en_US" />
    {type === 'article' && datePublished && <meta property="article:published_time" content={datePublished} />}
    {type === 'article' && <meta property="article:modified_time" content={dateModified} />}
    {type === 'article' && <meta property="article:author" content={`${SITE}/#orvi`} />}
    {type === 'article' && category && <meta property="article:section" content={category} />}
    {tags.map(tag => <meta property="article:tag" content={tag} />)}

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@robatdasorvi" />
    <meta name="twitter:creator" content="@robatdasorvi" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- LinkedIn -->
    <meta property="og:author" content={AUTHOR} />

    <!-- Web App Manifest -->
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Font preloads (served from /public/fonts/) -->
    <link rel="preload" href="/fonts/eb-garamond-v26-latin-regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-v12-latin-regular.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Google Fonts (deferred) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&family=Inter:wght@400;500;600&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Google Analytics 4 -->
    {GA4_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA4_ID}`}></script>
        <script define:vars={{ GA4_ID }} is:inline>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', GA4_ID);
        </script>
      </>
    )}

    <!-- ── Structured Data ────────────────────────────────────────────── -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {articleSchema && <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />}
    {breadcrumbs && <script type="application/ld+json" set:html={JSON.stringify(breadcrumbs)} />}

    <!-- Critical CSS to prevent FOUC -->
    <style is:inline>
      .page-content { opacity: 0; transition: opacity 0.25s ease; }
      html.js-ready .page-content { opacity: 1; }
      .skeleton-wrapper {
        position: fixed; inset: 0;
        background: #f5f1eb;
        z-index: 9999;
        opacity: 0; visibility: hidden;
        transition: opacity 0.25s, visibility 0.25s;
      }
      html.js-transitioning .skeleton-wrapper { opacity: 1; visibility: visible; }
      .search-modal, .search-results { display: none !important; }
    </style>

    <script is:inline>
      (function() {
        document.documentElement.classList.add('js-ready');
        document.addEventListener('astro:before-preparation', function() {
          document.documentElement.classList.remove('js-ready');
          document.documentElement.classList.add('js-transitioning');
        });
        document.addEventListener('astro:after-swap', function() {
          document.documentElement.classList.remove('js-transitioning');
          setTimeout(function() {
            document.documentElement.classList.add('js-ready');
          }, 80);
        });
      })();
    </script>

    <ViewTransitions />
  </head>
  <body>
    <div class="skeleton-wrapper">
      <div class="skeleton-content">
        <Skeleton type="title" width="60%" />
        <Skeleton type="paragraph" />
        <Skeleton type="paragraph" />
        <Skeleton type="image" />
        <Skeleton type="paragraph" />
      </div>
    </div>

    <div class="page-content">
      <Header currentPath={currentPath} />
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <SearchModal />
    <div id="modal-root"></div>
  </body>
</html>

<style>
  .skeleton-content {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem;
  }
</style>
