---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Glossary – The Book of Life";
const description = "A working vocabulary of terms as Orvi actually uses them — automation, presence, pivots, wrong turns, and more.";
const currentPath = "/glossary";

const terms = [
  { name: "Automation",     desc: "Removing process without removing thought. Or: the thing you build when you are too busy to notice you shouldn't be." },
  { name: "Itinerary",      desc: "A plan that prevents you from noticing what you actually came for." },
  { name: "Pivot",          desc: "What a founder calls a correction after calling it a strategy. Sometimes they are the same thing." },
  { name: "Pressing trigger", desc: "The moment when the cost of waiting exceeds the cost of committing." },
  { name: "Presence",       desc: "The thing automation removes when you aren't paying attention to what you are automating." },
  { name: "Self-awareness", desc: "Necessary but not sufficient for behaviour change. The vocabulary is not the cure." },
  { name: "Wrong turns",    desc: "How you find the places worth finding in an unfamiliar city. The technique generalises." },
  { name: "Systems thinking", desc: "A holistic approach that focuses on how a system's constituent parts interrelate and how systems work over time within larger contexts." },
];

const definedTermSetSchema = {
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "name": "The Book of Life Glossary",
  "description": description,
  "url": "https://www.robatdasorvi.com/glossary",
  "hasDefinedTerm": terms.map(t => ({
    "@type": "DefinedTerm",
    "name": t.name,
    "description": t.desc,
    "inDefinedTermSet": "https://www.robatdasorvi.com/glossary",
  })),
};
---

<BaseLayout title={title} description={description} currentPath={currentPath}>
  <script type="application/ld+json" set:html={JSON.stringify(definedTermSetSchema)} />

  <div class="simple-wrap">
    <div class="pg-title">Glossary</div>
    <div class="pg-rule"></div>

    <div class="pg-section">
      <div class="pg-sec-label">A Working Vocabulary</div>
      {terms.map(t => (
        <div class="pg-item">
          <div class="pg-item-title">{t.name}</div>
          <div class="pg-item-desc">{t.desc}</div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .simple-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 52px 40px 100px;
  }

  .pg-title {
    font-family: var(--font-serif);
    font-size: 42px;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 10px;
  }

  .pg-rule {
    width: 40px;
    height: 2px;
    background: var(--sienna);
    margin-bottom: 36px;
  }

  .pg-section {
    margin-bottom: 44px;
  }

  .pg-sec-label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sienna);
    margin-bottom: 18px;
    font-family: var(--font-sans);
  }

  .pg-item {
    padding: 16px 0;
    border-top: 1px solid var(--border);
  }

  .pg-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .pg-item-title {
    font-family: var(--font-serif);
    font-size: 19px;
    color: var(--ink);
    margin-bottom: 5px;
  }

  .pg-item-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
    font-family: var(--font-sans);
  }

  @media (max-width: 640px) {
    .simple-wrap { padding: 36px 24px 72px; }
    .pg-title { font-size: 32px; }
  }
</style>
