---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "About – The Book of Life";
const description = "Robat Das Orvi — writer, systems thinker, and co-founder of AgencyHandy and OneThread. On the essays, the questions underneath them, and the person writing.";
const currentPath = "/about";
---

<BaseLayout title={title} description={description} currentPath={currentPath}>
  <div class="simple-wrap">
    <div class="pg-title">About</div>
    <div class="pg-rule"></div>

    <div class="pg-bio">
      <p>These essays were written across three years, in airports, cafés, hotel rooms, and one football stadium. They were not written to be a book. They became one in retrospect, when I noticed the same questions surfacing in different clothes.</p>
      <p>The question underneath all of them: how do we pay attention to the right things? Technology automates it. Travel disrupts it. Startups consume it. Philosophy interrogates it. Football demands it for ninety minutes.</p>
      <p>I do not have a better answer. But I find the question worth asking every time.</p>
      <p>I co-created <a href="https://onethread.app" target="_blank" rel="noopener">OneThread</a> — a calm, focused workspace. And later, <a href="https://agencyhandy.com" target="_blank" rel="noopener">AgencyHandy</a> — a thoughtful system for client workflows. These are experiments in peace through product.</p>
      <div class="pg-sig">— Orvi, 2025</div>
    </div>
  </div>
</BaseLayout>

<style>
  .simple-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 52px 40px 100px;
  }

  .pg-title {
    font-family: var(--font-serif);
    font-size: 42px;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 10px;
  }

  .pg-rule {
    width: 40px;
    height: 2px;
    background: var(--sienna);
    margin-bottom: 36px;
  }

  .pg-bio {
    font-family: var(--font-serif);
    font-size: 20px;
    line-height: 1.82;
    color: var(--ink);
    max-width: 600px;
  }

  .pg-bio p {
    margin-bottom: 1.4em;
  }

  .pg-bio a {
    color: var(--sienna);
    text-decoration: underline;
    text-decoration-color: rgba(139,94,60,0.35);
    text-underline-offset: 2px;
  }

  .pg-sig {
    font-family: var(--font-sans);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--sienna);
    margin-top: 2em;
  }

  @media (max-width: 640px) {
    .simple-wrap { padding: 36px 24px 72px; }
    .pg-title { font-size: 32px; }
    .pg-bio { font-size: 17px; }
  }
</style>
