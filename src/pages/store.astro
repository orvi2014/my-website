---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Store & Projects – The Book of Life";
const description = "Current projects and a reading list.";
const currentPath = "/store";
---

<BaseLayout title={title} description={description} currentPath={currentPath}>
  <div class="simple-wrap">
    <div class="pg-title">Store &amp; Projects</div>
    <div class="pg-rule"></div>

    <div class="pg-section">
      <div class="pg-sec-label">Current Projects</div>

      <div class="pg-item">
        <div class="pg-item-title">ClassCatch</div>
        <div class="pg-item-desc">Copy Tailwind classes from any element or convert computed CSS to Tailwind utilities, instantly. <a href="https://robatdas.gumroad.com/l/classcatch" target="_blank" rel="noopener">Get it →</a></div>
      </div>

      <div class="pg-item">
        <div class="pg-item-title">AgencyHandy</div>
        <div class="pg-item-desc">A thoughtful system for client workflows. Built to reduce friction without removing judgment. <a href="https://agencyhandy.com" target="_blank" rel="noopener">Visit →</a></div>
      </div>

      <div class="pg-item">
        <div class="pg-item-title">The Book of Life</div>
        <div class="pg-item-desc">This collection. Always in progress.</div>
      </div>

      <div class="pg-item">
        <div class="pg-item-title">Attention Economy Notes</div>
        <div class="pg-item-desc">Ongoing research. No conclusions yet.</div>
      </div>
    </div>

    <div class="pg-section">
      <div class="pg-sec-label">Reading List</div>

      <div class="pg-item">
        <div class="pg-item-title">The Almanack of Naval Ravikant</div>
        <div class="pg-item-desc">On wealth and happiness. Dense and honest.</div>
      </div>

      <div class="pg-item">
        <div class="pg-item-title">Thinking in Systems — Meadows</div>
        <div class="pg-item-desc">The book that changed how I read anything.</div>
      </div>

      <div class="pg-item">
        <div class="pg-item-title">The Inner Game of Tennis — Gallwey</div>
        <div class="pg-item-desc">Nothing to do with tennis. Everything to do with attention.</div>
      </div>

      <div class="pg-item">
        <div class="pg-item-title">Fooled by Randomness — Taleb</div>
        <div class="pg-item-desc">The startup chapter owes this book a debt.</div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .simple-wrap {
    max-width: 720px;
    margin: 0 auto;
    padding: 52px 40px 100px;
  }

  .pg-title {
    font-family: var(--font-serif);
    font-size: 42px;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 10px;
  }

  .pg-rule {
    width: 40px;
    height: 2px;
    background: var(--sienna);
    margin-bottom: 36px;
  }

  .pg-section {
    margin-bottom: 44px;
  }

  .pg-sec-label {
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--sienna);
    margin-bottom: 18px;
    font-family: var(--font-sans);
  }

  .pg-item {
    padding: 16px 0;
    border-top: 1px solid var(--border);
  }

  .pg-item:last-child {
    border-bottom: 1px solid var(--border);
  }

  .pg-item-title {
    font-family: var(--font-serif);
    font-size: 19px;
    color: var(--ink);
    margin-bottom: 5px;
  }

  .pg-item-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.65;
    font-family: var(--font-sans);
  }

  .pg-item-desc a {
    color: var(--sienna);
    text-decoration: underline;
    text-decoration-color: rgba(139,94,60,0.35);
    text-underline-offset: 2px;
  }

  @media (max-width: 640px) {
    .simple-wrap { padding: 36px 24px 72px; }
    .pg-title { font-size: 32px; }
  }
</style>
