---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "The Book of Life — Orvi";
const description = "The Book of Life — personal essays on travel, AI, football, philosophy, and the human experience. By Robat Das Orvi, builder and writer from Bangladesh.";
const currentPath = "/";
const year = new Date().getFullYear();
---

<BaseLayout title={title} description={description} currentPath={currentPath}>
  <div class="cover-wrap">

    <div class="book-card">
      <div class="bc-bookmark"></div>
      <div class="bc-frame"></div>
      <div class="bc-corner tl"></div>
      <div class="bc-corner tr"></div>
      <div class="bc-corner bl"></div>
      <div class="bc-corner br"></div>

      <div class="bc-body">
        <div class="bc-eyebrow">Est. 1994 &nbsp;·&nbsp; First Edition</div>
        <div class="bc-hr">
          <span class="bc-hr-line"></span>
          <span class="bc-hr-diamond">◆</span>
          <span class="bc-hr-line"></span>
        </div>
        <div class="bc-title">The Book<br>of Life</div>
        <div class="bc-ornament">
          <span class="bc-orn-line"></span>
          <span class="bc-orn-glyph">❧</span>
          <span class="bc-orn-line"></span>
        </div>
        <div class="bc-subtitle">
          A collection of thoughts, experiences,<br>and discoveries
        </div>
        <div class="bc-topics">
          Travel &nbsp;·&nbsp; Technology &nbsp;·&nbsp; Startups<br>
          Philosophy &nbsp;·&nbsp; Psychology &nbsp;·&nbsp; Football
        </div>
      </div>

      <div class="bc-footer">
        <div class="bc-author">By Orvi</div>
        <div class="bc-edition">© 1994 · First Edition</div>
      </div>
    </div>

    <div class="cover-actions">
      <a href="/chapters" class="bc-open">Open Book</a>
      <p class="cover-hint">or click Chapters above</p>
    </div>

  </div>
</BaseLayout>

<style>
  .cover-wrap {
    min-height: calc(100vh - 54px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 28px 24px 40px;
    background: var(--bg);
  }

  /* ── Book card ── */
  .book-card {
    width: 420px;
    position: relative;
    background: linear-gradient(148deg, #2e1a08 0%, #1e1008 35%, #140c06 65%, #0c0804 100%);
    transform: perspective(1100px) rotateY(-3deg) rotateX(1.5deg);
    box-shadow:
      6px 18px 56px rgba(0,0,0,0.50),
      18px 36px 84px rgba(0,0,0,0.26),
      2px 4px 10px rgba(0,0,0,0.32);
    transition: transform 0.5s ease, box-shadow 0.5s ease;
  }

  .book-card:hover {
    transform: perspective(1100px) rotateY(-1deg) rotateX(0.5deg) translateY(-5px);
    box-shadow:
      10px 28px 76px rgba(0,0,0,0.50),
      26px 52px 100px rgba(0,0,0,0.22),
      2px 4px 10px rgba(0,0,0,0.28);
  }

  /* Page edges (right side) */
  .book-card::after {
    content: '';
    position: absolute;
    top: 5px; right: -13px; bottom: 5px;
    width: 15px;
    background: repeating-linear-gradient(
      to bottom,
      #f0e6d4 0, #f0e6d4 1.2px,
      #dfd2bc 1.6px, #dfd2bc 2.4px
    );
    box-shadow: 2px 0 8px rgba(0,0,0,0.10);
    border-radius: 0 2px 2px 0;
  }

  /* Spine (left side) */
  .book-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; bottom: 0;
    width: 11px;
    background: linear-gradient(to right, #060302 0%, #1a0a04 50%, #060302 100%);
  }

  /* Bookmark */
  .bc-bookmark {
    position: absolute;
    top: 0; right: 64px;
    width: 16px; height: 52px;
    background: linear-gradient(to bottom, #8a2525, #b03030);
    clip-path: polygon(0 0, 100% 0, 100% 80%, 50% 100%, 0 80%);
    box-shadow: -1px 2px 6px rgba(0,0,0,0.40);
    z-index: 2;
  }

  /* Inner frame */
  .bc-frame {
    position: absolute;
    inset: 16px 14px;
    border: 1px solid rgba(195,155,68,0.28);
    pointer-events: none;
    z-index: 1;
  }

  .bc-frame::before {
    content: '';
    position: absolute;
    inset: 5px;
    border: 1px solid rgba(195,155,68,0.12);
  }

  /* Corner ornaments */
  .bc-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    z-index: 2;
    pointer-events: none;
  }

  .bc-corner.tl { top: 22px;    left: 20px;  border-top: 1.5px solid rgba(195,155,68,0.42); border-left: 1.5px solid rgba(195,155,68,0.42); }
  .bc-corner.tr { top: 22px;    right: 20px; border-top: 1.5px solid rgba(195,155,68,0.42); border-right: 1.5px solid rgba(195,155,68,0.42); }
  .bc-corner.bl { bottom: 22px; left: 20px;  border-bottom: 1.5px solid rgba(195,155,68,0.42); border-left: 1.5px solid rgba(195,155,68,0.42); }
  .bc-corner.br { bottom: 22px; right: 20px; border-bottom: 1.5px solid rgba(195,155,68,0.42); border-right: 1.5px solid rgba(195,155,68,0.42); }

  /* Body */
  .bc-body {
    position: relative;
    z-index: 1;
    padding: 46px 40px 68px;
    display: flex;
    flex-direction: column;
  }

  .bc-eyebrow {
    font-size: 10px;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: rgba(196,156,70,0.62);
    margin-bottom: 18px;
    font-family: var(--font-sans);
  }

  .bc-hr {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 18px;
  }

  .bc-hr-line { flex: 1; height: 1px; background: rgba(195,155,68,0.34); }
  .bc-hr-diamond { font-size: 9px; color: rgba(200,162,72,0.52); }

  .bc-title {
    font-family: var(--font-serif);
    font-size: 68px;
    line-height: 0.92;
    letter-spacing: -0.025em;
    font-weight: 400;
    color: #f5e4c0;
    text-shadow: 0 2px 20px rgba(0,0,0,0.35);
    margin-bottom: 20px;
  }

  .bc-ornament {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }

  .bc-orn-line { width: 30px; height: 1px; background: rgba(195,155,68,0.36); }
  .bc-orn-glyph { font-size: 15px; color: rgba(200,162,72,0.52); font-family: serif; }

  .bc-subtitle {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(185,150,80,0.70);
    margin-bottom: 18px;
    font-family: var(--font-serif);
    font-style: italic;
  }

  .bc-topics {
    font-size: 12px;
    line-height: 1.9;
    color: rgba(175,140,72,0.52);
    font-family: var(--font-sans);
    letter-spacing: 0.02em;
  }

  /* Footer inside card */
  .bc-footer {
    position: absolute;
    bottom: 22px;
    left: 40px; right: 26px;
    border-top: 1px solid rgba(195,155,68,0.18);
    padding-top: 11px;
    display: flex;
    justify-content: space-between;
    z-index: 2;
  }

  .bc-author  { font-size: 10px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(196,152,70,0.65); font-family: var(--font-sans); }
  .bc-edition { font-size: 10px; color: rgba(160,125,55,0.40); font-family: var(--font-sans); }

  /* ── Actions below card ── */
  .cover-actions {
    margin-top: 22px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .bc-open {
    display: inline-block;
    padding: 12px 42px;
    border: 1px solid rgba(100,60,20,0.28);
    background: var(--ink);
    color: var(--bg);
    font-size: 15px;
    letter-spacing: 0.04em;
    cursor: pointer;
    font-family: var(--font-serif);
    border-radius: 2px;
    text-decoration: none;
    transition: background 0.18s, transform 0.14s, box-shadow 0.18s;
  }

  .bc-open:hover {
    background: #2e1e0e;
    transform: translateY(-1px);
    box-shadow: 0 4px 18px rgba(0,0,0,0.18);
  }

  .cover-hint {
    font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.05em;
    font-family: var(--font-sans);
  }

  @media (max-width: 480px) {
    .book-card { width: 320px; }
    .bc-title { font-size: 52px; }
    .bc-body { padding: 38px 30px 60px; }
    .bc-footer { left: 30px; right: 20px; }
  }
</style>
