---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

const title = "Chapters – The Book of Life";
const description = "Six chapters on travel, technology, startups, philosophy, psychology, and football. Long-form essays by Orvi.";
const currentPath = "/chapters";

const categories = await getCollection('categories');
const stories = await getCollection('stories');

const sortedCategories = categories.sort(
  (a: CollectionEntry<'categories'>, b: CollectionEntry<'categories'>) => a.data.order - b.data.order
);

const ROMANS = ['I','II','III','IV','V','VI','VII','VIII','IX','X'];

const catData = sortedCategories.map((cat: CollectionEntry<'categories'>, i: number) => {
  const catStories = stories
    .filter((s: CollectionEntry<'stories'>) => s.data.category === cat.slug)
    .sort((a: CollectionEntry<'stories'>, b: CollectionEntry<'stories'>) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
    )
    .map((s: CollectionEntry<'stories'>) => ({
      slug: s.slug,
      category: s.data.category,
      title: s.data.title,
      description: s.data.description || '',
      readingTime: s.data.readingTime || null,
      pubDate: s.data.pubDate instanceof Date ? s.data.pubDate.toISOString() : String(s.data.pubDate),
      tags: s.data.tags || [],
    }));

  return {
    slug: cat.slug,
    title: cat.data.title,
    description: cat.data.description,
    roman: ROMANS[i] || String(i + 1),
    pg: i * 6 + 1,
    stories: catStories,
  };
});

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "The Book of Life — Chapters",
  "description": description,
  "url": "https://www.robatdasorvi.com/chapters",
  "numberOfItems": catData.length,
  "itemListElement": catData.map((cat, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": cat.title,
    "description": cat.description,
    "url": `https://www.robatdasorvi.com/chapters/${cat.slug}`,
  })),
};
---

<BaseLayout title={title} description={description} currentPath={currentPath}>
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <div class="ch-scene">
    <div class="open-book">

      <!-- Left page: Table of Contents -->
      <div class="bl-page">
        <div class="page-head">
          <span>Table of Contents</span>
          <span>The Book of Life</span>
        </div>
        <div class="toc-header">Contents</div>
        <div class="toc-rule"></div>

        {catData.map((cat, i) => (
          <div class:list={['toc-entry', { active: i === 0 }]} data-idx={i}>
            <span class="toc-roman">{cat.roman}</span>
            <span class="toc-name">{cat.title}</span>
            <span class="toc-leader"></span>
            <span class="toc-pg">{cat.pg}</span>
          </div>
        ))}

        <div class="page-foot">
          <span>The Book of Life</span>
          <span>i</span>
        </div>
      </div>

      <!-- Spine -->
      <div class="book-spine">
        <div class="spine-title">The Book of Life · Orvi</div>
      </div>

      <!-- Right page: rendered by JS -->
      <div class="br-page" id="rightPage"></div>

    </div>
  </div>

  <script define:vars={{ catData }}>
    const STORY_NUMS = ['01','02','03','04','05','06','07','08','09','10','11','12','13','14','15'];
    const ITEMS_PER_PAGE = 5;

    let currentCat = null;
    let currentPage = 0;

    function renderRightPage(cat, page = 0) {
      currentCat = cat;
      currentPage = page;

      const rp = document.getElementById('rightPage');
      if (!rp) return;

      rp.style.opacity = '0';

      const stories = cat.stories || [];
      const totalPages = Math.max(1, Math.ceil(stories.length / ITEMS_PER_PAGE));
      const pageStories = stories.slice(page * ITEMS_PER_PAGE, (page + 1) * ITEMS_PER_PAGE);

      const storyRows = pageStories.map((s, i) => {
        const absIdx = page * ITEMS_PER_PAGE + i;
        const num = STORY_NUMS[absIdx] || String(absIdx + 1).padStart(2, '0');
        const meta = s.readingTime ? `${s.readingTime} min read` : '';
        return `<a class="rp-story" href="/chapters/${s.category}/${s.slug}">
          <span class="rp-s-num">${num}</span>
          <div class="rp-s-body">
            <div class="rp-s-title">${s.title}</div>
            ${meta ? `<div class="rp-s-meta">${meta}</div>` : ''}
          </div>
          <span class="rp-s-arrow">›</span>
        </a>`;
      }).join('');

      const empty = stories.length === 0
        ? '<p style="font-size:12px;color:rgba(90,70,50,0.5);padding:12px 0;">No stories in this chapter yet.</p>'
        : '';

      const pgFoot = totalPages > 1
        ? `<span class="rp-pg-nav">
            <button class="rp-pg-btn rp-pg-prev" ${page === 0 ? 'disabled' : ''}>‹</button>
            <span>${page + 1}&thinsp;/&thinsp;${totalPages}</span>
            <button class="rp-pg-btn rp-pg-next" ${page >= totalPages - 1 ? 'disabled' : ''}>›</button>
           </span>`
        : `<span>${cat.pg}</span>`;

      rp.innerHTML = `
        <div class="page-head">
          <span>Chapter ${cat.roman}</span>
          <span>The Book of Life</span>
        </div>
        <div class="rp-watermark">${cat.roman}</div>
        <div class="rp-ch-label">Chapter ${cat.roman}</div>
        <div class="rp-ch-title">${cat.title}</div>
        <div class="rp-ch-desc">${cat.description}</div>
        <div class="rp-divider"></div>
        ${storyRows}${empty}
        <div class="page-foot">
          <span>The Book of Life</span>
          ${pgFoot}
        </div>
      `;

      rp.querySelector('.rp-pg-prev')?.addEventListener('click', () => renderRightPage(currentCat, currentPage - 1));
      rp.querySelector('.rp-pg-next')?.addEventListener('click', () => renderRightPage(currentCat, currentPage + 1));

      requestAnimationFrame(() => { rp.style.opacity = '1'; });
    }

    function init() {
      if (catData.length > 0) renderRightPage(catData[0], 0);

      const entries = document.querySelectorAll('.toc-entry');
      entries.forEach((entry, i) => {
        entry.addEventListener('click', () => {
          entries.forEach(e => e.classList.remove('active'));
          entry.classList.add('active');
          renderRightPage(catData[i], 0);
        });
      });
    }

    document.addEventListener('astro:page-load', init);
  </script>

  <style is:global>
    .ch-scene {
      min-height: calc(100vh - 54px);
      display: flex;
      align-items: center;
      justify-content: center;
      background: #e6e0d6;
      padding: 32px 16px;
      overflow-x: auto;
    }

    .open-book {
      display: flex;
      width: min(880px, 98vw);
      height: clamp(480px, 62vh, 560px);
      transform: perspective(2000px) rotateX(2deg) rotateY(-0.8deg);
      filter:
        drop-shadow(0 26px 60px rgba(0,0,0,0.32))
        drop-shadow(0 6px 14px rgba(0,0,0,0.18));
      flex-shrink: 0;
    }

    .bl-page {
      flex: 0 0 calc(50% - 14px);
      background: linear-gradient(to right, #eee8de 0%, #faf7f2 70%);
      padding: 28px 30px 54px;
      position: relative;
      overflow: hidden;
      border-radius: 3px 0 0 3px;
      border-right: 1px solid rgba(0,0,0,0.07);
    }

    .book-spine {
      width: 28px;
      flex-shrink: 0;
      background: linear-gradient(to right, #0c0604 0%, #28160a 38%, #36200e 58%, #180c06 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: inset -3px 0 8px rgba(0,0,0,0.35), inset 3px 0 8px rgba(0,0,0,0.35);
    }

    .spine-title {
      writing-mode: vertical-lr;
      transform: rotate(180deg);
      font-family: var(--font-serif);
      font-size: 7px;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: rgba(210,170,90,0.50);
      white-space: nowrap;
      user-select: none;
    }

    .br-page {
      flex: 1;
      background: linear-gradient(to left, #eee8de 0%, #faf7f2 70%);
      padding: 28px 30px 54px;
      position: relative;
      overflow: hidden;
      border-radius: 0 3px 3px 0;
      border-left: 1px solid rgba(0,0,0,0.07);
      transition: opacity 0.18s ease;
    }

    .page-head {
      display: flex;
      justify-content: space-between;
      font-size: 8px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: rgba(90,70,50,0.45);
      margin-bottom: 22px;
      padding-bottom: 7px;
      border-bottom: 0.5px solid rgba(0,0,0,0.09);
      font-family: var(--font-sans);
    }

    .page-foot {
      position: absolute;
      bottom: 18px;
      left: 30px;
      right: 30px;
      display: flex;
      justify-content: space-between;
      font-size: 9px;
      color: rgba(90,70,50,0.42);
      font-family: var(--font-serif);
      border-top: 0.5px solid rgba(0,0,0,0.09);
      padding-top: 7px;
    }

    /* TOC — left page */
    .toc-header {
      font-family: var(--font-serif);
      font-size: 19px;
      font-weight: 400;
      color: #1e1006;
      margin-bottom: 8px;
      letter-spacing: 0.005em;
    }

    .toc-rule {
      width: 28px;
      height: 1px;
      background: var(--sienna);
      opacity: 0.7;
      margin-bottom: 18px;
    }

    .toc-entry {
      display: flex;
      align-items: baseline;
      padding: 9px 0;
      cursor: pointer;
      border-bottom: 0.5px solid rgba(0,0,0,0.07);
      transition: opacity 0.12s;
    }

    .toc-entry:hover .toc-name,
    .toc-entry.active .toc-name { color: var(--sienna); }
    .toc-entry.active .toc-roman { color: var(--sienna); }

    .toc-roman {
      font-family: var(--font-serif);
      font-size: 11px;
      font-style: italic;
      color: rgba(90,70,50,0.48);
      width: 24px;
      flex-shrink: 0;
      transition: color 0.12s;
    }

    .toc-name {
      font-family: var(--font-serif);
      font-size: 14.5px;
      color: #1e1006;
      flex: 1;
      min-width: 0;
      line-height: 1.25;
      transition: color 0.12s;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .toc-leader {
      flex: 1;
      border-bottom: 1px dotted rgba(0,0,0,0.18);
      margin: 0 8px;
      align-self: flex-end;
      margin-bottom: 3px;
    }

    .toc-pg {
      font-family: var(--font-serif);
      font-size: 11px;
      font-style: italic;
      color: rgba(90,70,50,0.48);
      flex-shrink: 0;
    }

    /* Right page — chapter content (JS-injected) */
    .rp-watermark {
      position: absolute;
      bottom: 46px;
      right: 18px;
      font-family: var(--font-serif);
      font-size: 100px;
      font-weight: 700;
      font-style: italic;
      color: rgba(0,0,0,0.035);
      line-height: 1;
      pointer-events: none;
      user-select: none;
    }

    .rp-ch-label {
      font-size: 9px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sienna);
      margin-bottom: 6px;
      opacity: 0.85;
      font-family: var(--font-sans);
    }

    .rp-ch-title {
      font-family: var(--font-serif);
      font-size: 21px;
      font-weight: 400;
      color: #1e1006;
      margin-bottom: 5px;
      line-height: 1.18;
    }

    .rp-ch-desc {
      font-size: 11.5px;
      color: rgba(90,70,50,0.62);
      line-height: 1.58;
      margin-bottom: 16px;
      font-family: var(--font-sans);
    }

    .rp-divider {
      width: 24px;
      height: 1px;
      background: var(--sienna);
      opacity: 0.55;
      margin-bottom: 14px;
    }

    .rp-story {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      padding: 9px 6px;
      margin: 0 -6px;
      border-radius: 3px;
      cursor: pointer;
      transition: background 0.12s;
      border-bottom: 0.5px solid rgba(0,0,0,0.07);
      text-decoration: none;
      color: inherit;
    }

    .rp-story + .rp-story { }
    .br-page .rp-story:first-of-type { border-top: 0.5px solid rgba(0,0,0,0.07); }
    .rp-story:hover { background: rgba(139,94,60,0.07); }
    .rp-story:hover .rp-s-title { color: var(--sienna); }

    .rp-s-num {
      font-family: var(--font-serif);
      font-size: 10px;
      font-style: italic;
      color: rgba(90,70,50,0.42);
      width: 20px;
      flex-shrink: 0;
      padding-top: 3px;
    }

    .rp-s-body { flex: 1; min-width: 0; }

    .rp-s-title {
      font-family: var(--font-serif);
      font-size: 15px;
      color: #1e1006;
      line-height: 1.28;
      margin-bottom: 3px;
      transition: color 0.12s;
    }

    .rp-s-meta {
      font-size: 10.5px;
      color: rgba(90,70,50,0.52);
      font-family: var(--font-sans);
    }

    .rp-s-arrow {
      font-size: 12px;
      color: rgba(90,70,50,0.36);
      flex-shrink: 0;
      padding-top: 3px;
    }

    .rp-pg-nav {
      display: flex;
      align-items: center;
      gap: 3px;
    }

    .rp-pg-btn {
      background: none;
      border: none;
      cursor: pointer;
      font-family: var(--font-serif);
      font-size: 13px;
      color: rgba(90,70,50,0.6);
      padding: 0 1px;
      line-height: 1;
    }

    .rp-pg-btn:disabled { opacity: 0.25; cursor: default; }
    .rp-pg-btn:not(:disabled):hover { color: var(--sienna); }

    @media (max-width: 680px) {
      .open-book {
        height: auto;
        flex-direction: column;
        transform: none;
        filter: drop-shadow(0 8px 28px rgba(0,0,0,0.22));
      }
      .bl-page, .br-page {
        border-radius: 0;
        flex: none;
        width: 100%;
        height: auto;
      }
      .book-spine {
        width: 100%;
        height: 18px;
        flex-direction: row;
      }
      .spine-title {
        writing-mode: horizontal-tb;
        transform: none;
        font-size: 7px;
      }
      .toc-leader { display: none; }
    }
  </style>
</BaseLayout>
