---
interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const nav = [
  { href: '/',          id: 'cover',    label: 'Cover'    },
  { href: '/chapters',  id: 'chapters', label: 'Chapters' },
  { href: '/store',     id: 'store',    label: 'Store'    },
  { href: '/glossary',  id: 'glossary', label: 'Glossary' },
  { href: '/about',     id: 'about',    label: 'About'    },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<header class="topnav">
  <a href="/" class="nav-logo">RDO</a>
  <nav class="nav-links" aria-label="Main navigation">
    {nav.map(({ href, label }) => (
      <a href={href} class:list={['nl', { active: isActive(href) }]}>
        {label}
      </a>
    ))}
  </nav>
  <button class="nav-search" id="searchToggle" aria-label="Search" title="Search">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="11" cy="11" r="8"></circle>
      <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
    </svg>
  </button>
</header>

<style>
  .topnav {
    position: sticky;
    top: 0;
    z-index: 200;
    height: 54px;
    display: flex;
    align-items: center;
    padding: 0 40px;
    background: rgba(245,241,235,0.97);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
  }

  .nav-logo {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    color: var(--accent);
    letter-spacing: 0.02em;
    margin-right: auto;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 2px;
    align-items: center;
  }

  .nl {
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--muted);
    padding: 8px 16px;
    border-radius: 4px;
    text-decoration: none;
    letter-spacing: 0.01em;
    transition: color 0.15s, background 0.15s;
    border-bottom: 2px solid transparent;
  }

  .nl:hover {
    color: var(--ink);
    background: rgba(0,0,0,0.04);
  }

  .nl.active {
    color: var(--accent);
    border-bottom: 2px solid var(--accent);
    border-radius: 0 0 2px 2px;
    padding-bottom: 6px;
  }

  .nav-search {
    margin-left: 14px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    padding: 6px;
    display: flex;
    align-items: center;
    line-height: 1;
    transition: color 0.15s;
    border-radius: 4px;
  }

  .nav-search:hover {
    color: var(--ink);
  }

  @media (max-width: 640px) {
    .topnav { padding: 0 16px; }
    .nl { padding: 6px 10px; font-size: 12px; }
  }

  @media (max-width: 480px) {
    .nl:not(.active) { display: none; }
  }
</style>

<script>
  document.getElementById('searchToggle')?.addEventListener('click', () => {
    (window as any).openSearchModal?.();
  });
</script>
