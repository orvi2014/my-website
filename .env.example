# ── Google Tag Manager ─────────────────────────────────────────────────────
# Get from tagmanager.google.com → your container → Admin → Container ID
PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Google Analytics 4 (only if not using GTM) ─────────────────────────────
# Get from analytics.google.com → Admin → Data Streams → Measurement ID
PUBLIC_GA4_ID=G-XXXXXXXXXX

# ── Google Search Console verification ─────────────────────────────────────
# 1. Go to search.google.com/search-console
# 2. Add property → URL prefix → https://robatdasorvi.com
# 3. Choose "HTML tag" verification method
# 4. Copy the content="" value (looks like: abc123xyz...)
# 5. Paste it below (without the full meta tag, just the value)
PUBLIC_GSC_VERIFICATION=

# ── Supabase (newsletter) ──────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── GSC API monitoring (for scripts/seo-monitor.sh) ───────────────────────
# Path to your Google service account JSON key file
# GSC_SERVICE_KEY=/path/to/service-account.json
# GSC_SITE=https://robatdasorvi.com
