{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "astro",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/index", "destination": "/", "permanent": true },
    { "source": "/chapters/about", "destination": "/about", "permanent": true },
    { "source": "/stories", "destination": "/chapters", "permanent": true },
    { "source": "/stories/race", "destination": "/chapters/technology/race", "permanent": true },
    { "source": "/stories/love-never-dies", "destination": "/chapters/human/love-never-dies", "permanent": true },
    { "source": "/stories/classcatch", "destination": "/chapters/extensions/classcatch", "permanent": true },
    { "source": "/stories/why-does-universe-have-laws", "destination": "/chapters/philosophy/why-does-universe-have-laws", "permanent": true },
    { "source": "/chapters/stories/race", "destination": "/chapters/technology/race", "permanent": true },
    { "source": "/chapters/stories/love-never-dies", "destination": "/chapters/human/love-never-dies", "permanent": true },
    { "source": "/chapters/stories/classcatch", "destination": "/chapters/extensions/classcatch", "permanent": true },
    { "source": "/chapters/stories/why-does-universe-have-laws", "destination": "/chapters/philosophy/why-does-universe-have-laws", "permanent": true },
    { "source": "/chapters/stories", "destination": "/chapters", "permanent": true },
    { "source": "/chapters/first-chapter", "destination": "/chapters", "permanent": true }
  ]
} 